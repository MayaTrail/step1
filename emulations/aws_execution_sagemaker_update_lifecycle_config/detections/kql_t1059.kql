// Malicious Script Execution via SageMaker Lifecycle Config (T1059) — eventName(s) auto-derived; verify casing.
// Signal: CloudTrail sagemaker:UpdateNotebookInstanceLifecycleConfig with a base64-encoded OnStart script from an unexpected principal
AWSCloudTrail
| where EventSource in ("sagemaker.amazonaws.com")
| where EventName in ("UpdateNotebookInstanceLifecycleConfig", "DescribeNotebookInstanceLifecycleConfig")
| project TimeGenerated, UserIdentityArn, EventName, SourceIpAddress, AWSRegion
| order by TimeGenerated desc
