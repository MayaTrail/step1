{
  "techniques": [
    {
      "mitre_id": "T1078.004",
      "name": "Valid Accounts: Cloud Accounts",
      "tactic": "Initial Access",
      "platform": "aws",
      "execution_plane": "control_plane",
      "execution_context": "api_attack",
      "emulation_category": "emulated",
      "description": "Use compromised long-term IAM access key pair to authenticate to AWS APIs.",
      "api_calls": [
        "sts:GetCallerIdentity",
        "s3:ListBuckets",
        "s3:ListObjectsV2"
      ],
      "data_plane_actions": [],
      "host_commands": [],
      "expected_audit_events": [
        {
          "eventName": "GetCallerIdentity",
          "eventSource": "sts.amazonaws.com"
        },
        {
          "eventName": "ListBuckets",
          "eventSource": "s3.amazonaws.com"
        },
        {
          "eventName": "ListObjects",
          "eventSource": "s3.amazonaws.com"
        }
      ],
      "audit_visible": true,
      "detection_sources": [
        "CloudTrail",
        "SIEM"
      ],
      "expected_alert_findings": [
        "GuardDuty: UnauthorizedAccess:IAMUser/InstanceCredentialExfiltration",
        "GuardDuty: Discovery:S3/MaliciousIPCaller"
      ],
      "phase_in_chain": 1,
      "dependencies": [],
      "severity": "critical",
      "resources_needed": {
        "attack_surface": [
          "Exposed IAM access key ID and secret"
        ],
        "target": [
          "AWS account with S3 read/write permissions"
        ],
        "bait": []
      },
      "cleanup_actions": [
        "Rotate or deactivate IAM access key used"
      ],
      "opsec_notes": "Long-term IAM keys leave persistent CloudTrail entries tied to AccessKeyId; no MFA required for API calls."
    },
    {
