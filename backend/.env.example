# Django
DJANGO_SETTINGS_MODULE=config.settings.dev
SECRET_KEY=change-me-in-production

# Database (PostgreSQL)
DATABASE_URL=postgres://mayatrail:mayatrail@db:5432/mayatrail

# Redis / Celery
REDIS_URL=redis://redis:6379/0

# AWS credentials used for STS assume-role calls (platform-level).
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=ap-south-1

# Pulumi state backend (S3 bucket name — no s3:// prefix)
STATE_BUCKET=mayatrail-state-bucket

# Pulumi secrets passphrase — must match the value used when stacks were first created.
# Enterprise stacks: this encrypts stack config secrets in the S3 state backend.
# Changing this value after stacks exist will make existing state unreadable.
PULUMI_CONFIG_PASSPHRASE=

# Emulations package base directory.
# Each emulation's Pulumi program lives at {EMULATIONS_BASE_DIR}/{type}/infra/.
# Docker: set to the container path where emulations/ is mounted (e.g. /opt/emulations).
# Local dev: set to the absolute path of the step1/emulations/ directory.
EMULATIONS_BASE_DIR=

# Registration gate — set a non-empty value to require an invite code for signup.
# Leave empty to allow open registration.
REGISTRATION_INVITE_CODE=

# Google OAuth — obtain from Google Cloud Console -> APIs & Services -> Credentials.
# Required for the "Continue with Google" login/signup flow.
# Leave empty to disable the Google OAuth button on the login page.
GOOGLE_CLIENT_ID=

# AI assistant — Fernet key encrypting stored LLM API keys at rest. Generate with:
#   python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
# Leave empty to disable AI key storage (the connector endpoints return 503).
LLM_FERNET_KEY=
